FROM node:20-alpine

# Instalar herramientas necesarias para watch mode
RUN apk add --no-cache python3 make g++

WORKDIR /app

# Copiar solo los archivos de dependencias primero (capa de caché)
COPY package*.json ./
RUN npm install --legacy-peer-deps

# El código fuente se monta como volumen en docker-compose (no se copia aquí)
# Esto permite hot-reload sin reconstruir la imagen

EXPOSE 3000

# Iniciar en modo watch (hot-reload)
CMD ["npm", "run", "dev"]

