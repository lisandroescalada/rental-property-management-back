# MySQL Configuration
MYSQL_ROOT_PASSWORD=contraseรฑasegura
MYSQL_DATABASE=rentals_db
MYSQL_USER=rentals_user
MYSQL_PASSWORD=contraseรฑasegura

# Backend Configuration
NODE_ENV=development
PORT=3000
CORS_ORIGIN=*

# Database Configuration (TypeORM)
DB_HOST=localhost
DB_PORT=3306
DB_USER=${MYSQL_USER}
